{% comment %} Footer - Thème NOVAIA {% endcomment %}

<footer class="footer color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="footer__content">
      <div class="footer__blocks">
        {% for block in section.blocks %}
          <div class="footer-block" {{ block.shopify_attributes }}>
            {% case block.type %}
              {% when 'text' %}
                <h2 class="footer-block__heading">BestDeals</h2>
                <div class="footer-block__details-content rte">
                  {{ block.settings.subtext }}
                </div>
                
              {% when 'link_list' %}
                <h2 class="footer-block__heading">{{ block.settings.heading }}</h2>
                <ul class="footer-block__details-content list-unstyled">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}" class="link link--text">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
                
              {% when 'newsletter' %}
                <h2 class="footer-block__heading">Newsletter</h2>
                <div class="footer-block__details-content">
                  <p>Inscrivez-vous pour recevoir nos offres exclusives de BestDeals</p>
                  {% form 'customer', class: 'footer__newsletter newsletter-form' %}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="newsletter-form__field-wrapper">
                      <input type="email" name="contact[email]" placeholder="Votre email" required>
                      <button type="submit" class="button button--secondary">S'inscrire</button>
                    </div>
                  {% endform %}
                </div>
            {% endcase %}
          </div>
        {% endfor %}
      </div>
      
      <div class="footer__bottom">
        <div class="footer__copyright">
          <p>&copy; {{ 'now' | date: "%Y" }} BestDeals. Tous droits réservés.</p>
        </div>
        
        <div class="footer__payment-icons">
          <span class="visually-hidden">Moyens de paiement acceptés</span>
          <ul class="list list-payment">
            <li class="list-payment__item">
              <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="Visa"><path fill="#1A1F71" d="M0 0h38v24H0z"/><path fill="#FFF" d="M17.5 16.5l2-12h3l-2 12h-3z"/></svg>
            </li>
            <li class="list-payment__item">
              <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="Mastercard"><path fill="#EB001B" d="M0 0h38v24H0z"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="23" cy="12" r="7" fill="#F79E1B"/></svg>
            </li>
            <li class="list-payment__item">
              <svg viewBox="0 0 38 24" width="38" height="24" role="img" aria-label="PayPal"><path fill="#003087" d="M0 0h38v24H0z"/><text x="5" y="16" fill="#FFF" font-size="10" font-weight="bold">PayPal</text></svg>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    padding: 3rem 0 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .footer__content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .footer__blocks {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }
  
  .footer-block__heading {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }
  
  .footer-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer-block li {
    margin-bottom: 0.5rem;
  }
  
  .footer-block a {
    color: var(--color-foreground);
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  
  .footer-block a:hover {
    opacity: 1;
  }
  
  .footer__newsletter input {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: white;
    width: 100%;
    margin-bottom: 0.5rem;
  }
  
  .footer__newsletter input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .footer__copyright {
    font-size: 0.875rem;
    opacity: 0.7;
  }
  
  .list-payment {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        }
      ],
      "default": "background-2",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Texte",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "À propos",
          "label": "Titre"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Votre boutique en ligne de confiance</p>",
          "label": "Texte"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Liens",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Liens rapides",
          "label": "Titre"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1
    }
  ]
}
{% endschema %}