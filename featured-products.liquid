{% comment %} Produits en vedette - Thème NOVAIA {% endcomment %}

<div class="featured-products color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <h2 class="featured-products__heading">{{ section.settings.title | default: "Nos Bestsellers" }}</h2>
    
    <div class="featured-products__grid grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col">
      {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
        <div class="featured-products__item">
          {% render 'card-product', 
            card_product: product,
            show_secondary_image: true,
            show_vendor: true,
            show_rating: true
          %}
        </div>
      {% else %}
        {% comment %} Produit scrapé depuis AliExpress {% endcomment %}
        <div class="featured-products__item">
          <div class="card-wrapper">
            <div class="card card--media card--aliexpress">
              <div class="card__inner">
                <div class="card__badge">
                  <span class="badge badge--sale">-30%</span>
                  <span class="badge badge--new">Nouveau</span>
                </div>
                <a href="#product" class="card__media media media--square">
                  <img src="https://ae01.alicdn.com/kf/Sa22897381c0e495aa7b884f079f34cef0.jpg" alt="Xiaomi-Tablette Pad 7, 11 " loading="lazy" style="width:100%;height:100%;object-fit:cover;">
                </a>
              </div>
              <div class="card__content">
                <h3 class="card__heading">Xiaomi-Tablette Pad 7, 11 </h3>
                <div class="card__information">
                  <p class="card__description">Smarter Shopping, Better Living! Aliexpress.com...</p>
                  <div class="card__price-rating">
                    <span class="price price--sale">42,99 €</span>
                    <span class="price price--compare">58.80€</span>
                  </div>
                  <div class="card__rating">
                    ⭐⭐⭐⭐⭐ <span class="reviews">(1,247 avis)</span>
                  </div>
                </div>
                <a href="#add-to-cart" class="button button--primary button--full-width">
                  🛒 Ajouter au panier
                </a>
              </div>
            </div>
          </div>
        </div>
        
        {% comment %} Produits similaires générés {% endcomment %}
        
        <div class="featured-products__item">
          <div class="card-wrapper">
            <div class="card card--media">
              <div class="card__inner">
                <div class="card__media media media--square placeholder">
                  {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </div>
              <div class="card__content">
                <h3 class="card__heading">Variante 2 - Xiaomi-Tablette Pad </h3>
                <div class="card__information">
                  <span class="price">42.00€</span>
                </div>
                <a href="#" class="button button--secondary button--full-width">Voir détails</a>
              </div>
            </div>
          </div>
        </div>
        
        <div class="featured-products__item">
          <div class="card-wrapper">
            <div class="card card--media">
              <div class="card__inner">
                <div class="card__media media media--square placeholder">
                  {{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </div>
              <div class="card__content">
                <h3 class="card__heading">Variante 3 - Xiaomi-Tablette Pad </h3>
                <div class="card__information">
                  <span class="price">46.20€</span>
                </div>
                <a href="#" class="button button--secondary button--full-width">Voir détails</a>
              </div>
            </div>
          </div>
        </div>
        
        <div class="featured-products__item">
          <div class="card-wrapper">
            <div class="card card--media">
              <div class="card__inner">
                <div class="card__media media media--square placeholder">
                  {{ 'product-4' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </div>
              <div class="card__content">
                <h3 class="card__heading">Variante 4 - Xiaomi-Tablette Pad </h3>
                <div class="card__information">
                  <span class="price">50.40€</span>
                </div>
                <a href="#" class="button button--secondary button--full-width">Voir détails</a>
              </div>
            </div>
          </div>
        </div>
        
      {% endfor %}
    </div>
    
    {% if section.settings.show_view_all %}
      <div class="center">
        <a href="/collections/all" class="button button--secondary">Voir tous les produits</a>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .featured-products {
    padding: 4rem 0;
    background: linear-gradient(180deg, var(--color-background) 0%, var(--color-surface) 100%);
  }
  
  .featured-products__heading {
    text-align: center;
    margin-bottom: 2.5rem;
    font-size: 2.5rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }
  
  .card-wrapper {
    height: 100%;
  }
  
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border-radius: 16px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    transition: all 0.3s ease;
  }
  
  .card:hover {
    transform: translateY(-8px);
    border-color: var(--color-purple);
    box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
  }
  
  .card--aliexpress {
    border: 2px solid var(--color-purple);
    position: relative;
  }
  
  .card--aliexpress::before {
    content: "IMPORTÉ ALIEXPRESS";
    position: absolute;
    top: 10px;
    right: -30px;
    background: var(--gradient-primary);
    color: white;
    padding: 4px 40px;
    font-size: 0.7rem;
    font-weight: 700;
    transform: rotate(45deg);
    z-index: 10;
  }
  
  .card__inner {
    position: relative;
    overflow: hidden;
  }
  
  .card__media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-surface);
  }
  
  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .card:hover .card__media img {
    transform: scale(1.08);
  }
  
  .card__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    display: flex;
    gap: 0.5rem;
    z-index: 5;
  }
  
  .badge {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }
  
  .badge--sale {
    background: #EF4444;
    color: white;
  }
  
  .badge--new {
    background: #10B981;
    color: white;
  }
  
  .card__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  
  .card__heading {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    line-height: 1.4;
    color: var(--color-text);
  }
  
  .card__description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  
  .card__information {
    margin-bottom: 1rem;
  }
  
  .card__price-rating {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  
  .price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-purple);
  }
  
  .price--sale {
    color: #10B981;
  }
  
  .price--compare {
    font-size: 1rem;
    text-decoration: line-through;
    color: var(--color-text-muted);
    font-weight: 400;
  }
  
  .card__rating {
    font-size: 0.875rem;
    color: #FBBF24;
    margin-bottom: 1rem;
  }
  
  .reviews {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  
  .button {
    padding: 1rem 1.5rem;
    font-weight: 600;
    border-radius: 12px;
    transition: all 0.3s ease;
  }
  
  .button--full-width {
    width: 100%;
    margin-top: auto;
  }
  
  .placeholder {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
  }
  
  .placeholder svg {
    width: 80%;
    height: 80%;
    opacity: 0.3;
  }
  
  @media (max-width: 768px) {
    .featured-products__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    
    .featured-products__heading {
      font-size: 1.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Produits en vedette",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Nos Bestsellers",
      "label": "Titre"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Nombre de produits"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Colonnes sur desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2",
      "label": "Colonnes sur mobile"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Afficher bouton 'Voir tout'"
    }
  ],
  "presets": [
    {
      "name": "Produits en vedette"
    }
  ]
}
{% endschema %}