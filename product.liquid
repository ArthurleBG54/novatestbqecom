{% comment %} Template Produit - Thème NOVAIA {% endcomment %}

<section class="section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="product product--{{ section.settings.media_size }} grid grid--1-col grid--2-col-tablet">
      
      {% comment %} Galerie d'images {% endcomment %}
      <div class="product__media-wrapper">
        <div class="product__media media media--transparent">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | escape }}"
              class="product__media-image"
              loading="eager"
              width="800"
              height="800">
          {% else %}
            <div class="product__media media media--square placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>
        
        {% if product.images.size > 1 %}
          <div class="product__media-thumbnails">
            {% for image in product.images limit: 4 %}
              <button class="thumbnail" data-media-id="{{ image.id }}">
                <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" loading="lazy">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% comment %} Informations produit {% endcomment %}
      <div class="product__info-wrapper">
        <div class="product__info-container">
          
          {% comment %} Breadcrumb {% endcomment %}
          <nav class="breadcrumb" role="navigation" aria-label="breadcrumbs">
            <a href="{{ routes.root_url }}" class="breadcrumb__link">Accueil</a>
            {% if product.collections.first %}
              <span class="breadcrumb__divider">/</span>
              <a href="{{ product.collections.first.url }}" class="breadcrumb__link">{{ product.collections.first.title }}</a>
            {% endif %}
            <span class="breadcrumb__divider">/</span>
            <span class="breadcrumb__current">{{ product.title }}</span>
          </nav>

          {% comment %} Titre {% endcomment %}
          <h1 class="product__title">{{ product.title }}</h1>
          
          {% comment %} Avis {% endcomment %}
          <div class="product__reviews">
            <div class="stars">
              {% for i in (1..5) %}
                <svg class="star star--full" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>
            <span class="reviews-count">(128 avis)</span>
          </div>

          {% comment %} Prix {% endcomment %}
          <div class="product__price">
            <span class="price-item price-item--sale price-item--large">
              {{ product.price | money }}
            </span>
            {% if product.compare_at_price > product.price %}
              <span class="price-item price-item--regular price-item--large">
                {{ product.compare_at_price | money }}
              </span>
              <span class="badge badge--sale">-{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%</span>
            {% endif %}
          </div>

          {% comment %} Description courte {% endcomment %}
          <div class="product__description rte">
            {{ product.description | truncatewords: 30 }}
          </div>

          {% comment %} Avantages {% endcomment %}
          <div class="product__features">
            <h3>Points forts :</h3>
            <ul class="feature-list">
              <li>✅ Produit sélectionné pour sa qualité et son efficacité</li>
<li>✅ Prix compétitif avec garantie satisfaction</li>
<li>✅ Livraison rapide et service client réactif</li>
<li>✅ Des milliers de clients satisfaits</li>
<li>✅ Retour gratuit sous 30 jours si insatisfait</li>
            </ul>
          </div>

          {% comment %} Variantes et Add to Cart {% endcomment %}
          {% form 'product', product, id: 'product-form', class: 'product-form' %}
            
            {% if product.variants.size > 1 %}
              <div class="product-form__variants">
                {% for option in product.options_with_values %}
                  <div class="product-form__input">
                    <label class="form__label">{{ option.name }}</label>
                    <div class="variant-options">
                      {% for value in option.values %}
                        <input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                          name="{{ option.name }}"
                          value="{{ value | escape }}"
                          form="product-form"
                          {% if option.selected_value == value %}checked{% endif %}
                        >
                        <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                          {{ value }}
                        </label>
                      {% endfor %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            {% endif %}

            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            {% comment %} Quantity and Add to Cart {% endcomment %}
            <div class="product-form__buttons">
              <div class="quantity-wrapper">
                <label for="Quantity-{{ section.id }}" class="quantity__label form__label">Quantité</label>
                <quantity-input class="quantity">
                  <button class="quantity__button no-js-hidden" name="minus" type="button">
                    <span class="visually-hidden">Diminuer</span>
                    <svg width="12" height="12" viewBox="0 0 12 12"><path d="M0 6h12" stroke="currentColor" stroke-width="1.5"/></svg>
                  </button>
                  <input class="quantity__input" type="number" name="quantity" id="Quantity-{{ section.id }}" min="1" value="1" form="product-form">
                  <button class="quantity__button no-js-hidden" name="plus" type="button">
                    <span class="visually-hidden">Augmenter</span>
                    <svg width="12" height="12" viewBox="0 0 12 12"><path d="M6 0v12M0 6h12" stroke="currentColor" stroke-width="1.5"/></svg>
                  </button>
                </quantity-input>
              </div>

              <button type="submit" name="add" class="product-form__submit button button--full-width button--primary" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                <span>
                  {% if product.selected_or_first_available_variant.available %}
                    Ajouter au panier
                  {% else %}
                    Épuisé
                  {% endif %}
                </span>
                <div class="loading-overlay__spinner hidden">
                  <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </button>
            </div>

            {{ form | payment_terms }}
          {% endform %}

          {% comment %} Trust badges {% endcomment %}
          <div class="trust-badges">
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              <span>Paiement sécurisé</span>
            </div>
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span>Livraison rapide</span>
            </div>
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span>Garantie 30 jours</span>
            </div>
          </div>

          {% comment %} Description complète {% endcomment %}
          <div class="product__description-full rte">
            <h3>Description complète</h3>
            {{ product.description }}
          </div>

        </div>
      </div>
    </div>
  </div>
</section>